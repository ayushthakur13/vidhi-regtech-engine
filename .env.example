# Local dev — matches docker-compose.yml defaults
DATABASE_URL=
REDIS_URL=

# Get one at https://console.groq.com
GROQ_API_KEY=

# Model used for grounded obligation extraction
GROQ_MODEL=llama-3.3-70b-versatile

# Embedding dim must match db/schema.sql (default 384 for all-MiniLM-L6-v2)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
